# Copy to `.env` for LOCAL runs only. NEVER commit real values.
# In production these are GitHub Actions Secrets/Variables (see README), not a file.

# Slack USER token (xoxp-...) — posts AS you and reads the Canvas. REQUIRED.
SLACK_USER_TOKEN=xoxp-...

# The Canvas source. Provide ONE of these:
#   - the channel that hosts the Canvas (bot resolves channel.properties.canvas), or
#   - a direct Canvas file id (Fxxxx).
SLACK_CANVAS_CHANNEL_ID=C0123456789
# SLACK_CANVAS_ID=F0123456789

# Where reminders are posted. Use your DM id while testing, then the real channel id. REQUIRED.
SLACK_TARGET=D0123456789

# Where parse-failure alerts go (defaults to SLACK_TARGET if unset).
OWNER_ALERT_TARGET=D0123456789

# Fallback lead time (minutes before) when the Canvas omits `default_offset`.
DEFAULT_OFFSET_MIN=10

# Grace window (minutes after a prayer time) a delayed run may still fire in.
GRACE_MIN=5

# Fallback weekend days when the Canvas omits `Weekend:`.
WEEKEND_DAYS=Sat,Sun

# IANA timezone used for all time math.
TIMEZONE=Asia/Karachi

# Where dedupe markers are written/committed.
STATE_DIR=state

# Set true to log what WOULD be posted without posting.
DRY_RUN=false

# Soft app-level enable (the workflow also gates via the REMINDERS_ENABLED repo variable).
REMINDERS_ENABLED=true
