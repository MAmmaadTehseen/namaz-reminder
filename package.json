{
  "name": "namaz-reminder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Slack namaz (prayer) reminders driven by an editable Slack Canvas, run on GitHub Actions.",
  "scripts": {
    "tick": "tsx scripts/tick.ts",
    "tick:local": "tsx --env-file=.env scripts/tick.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "next": "^15.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
